---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const isES = lang === 'es';
---

<div class="card overflow-hidden">
  <div class="p-5 md:p-6 border-b border-[color:var(--color-border)]">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <p class="font-mono text-xs text-[color:var(--color-accent)] mb-1">// {t('project.tags.demo')}</p>
        <h3 class="text-lg font-semibold">{t('cotton.demoTitle')}</h3>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge badge-accent">
          <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
          {isES ? 'EN VIVO (simulado)' : 'LIVE (simulated)'}
        </span>
      </div>
    </div>
    <p class="text-sm text-[color:var(--color-fg-muted)] mt-2 max-w-2xl">{t('cotton.demoDesc')}</p>
  </div>

  <div class="grid lg:grid-cols-[2fr_1fr] gap-0">
    <div class="relative bg-black aspect-video overflow-hidden border-b lg:border-b-0 lg:border-r border-[color:var(--color-border)]">
      <div id="cotton-scene" class="absolute inset-0">
        <svg viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice" class="absolute inset-0 w-full h-full">
          <defs>
            <pattern id="floor-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1a2433" stroke-width="0.5"/>
            </pattern>
            <linearGradient id="bg-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#0f1620"/>
              <stop offset="1" stop-color="#1a2433"/>
            </linearGradient>
          </defs>
          <rect width="800" height="450" fill="url(#bg-grad)"/>
          <rect width="800" height="450" fill="url(#floor-grid)"/>

          <text x="20" y="34" font-family="monospace" font-size="13" fill="#34d399">CAM-01 · CEDIS</text>
          <text x="20" y="52" font-family="monospace" font-size="11" fill="#6b7689">YOLO11-seg · TensorRT FP16</text>
          <text x="680" y="34" font-family="monospace" font-size="11" fill="#6b7689" id="cotton-fps">FPS: 28.4</text>
          <text x="680" y="48" font-family="monospace" font-size="11" fill="#6b7689" id="cotton-time">t=0.0s</text>

          <g opacity="0.5">
            <rect x="120" y="120" width="180" height="200" fill="#2a3441" stroke="#3a4555" stroke-width="1"/>
            <rect x="350" y="100" width="150" height="220" fill="#252e3a" stroke="#3a4555" stroke-width="1"/>
            <rect x="550" y="130" width="170" height="190" fill="#2a3441" stroke="#3a4555" stroke-width="1"/>
          </g>

          <g id="cotton-boxes"></g>
        </svg>
      </div>
    </div>

    <div class="p-5 md:p-6">
      <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-fg-dim)] mb-3">
        {isES ? 'Detecciones' : 'Detections'}
      </p>
      <div id="cotton-detections" class="space-y-2 max-h-[360px] overflow-y-auto"></div>

      <div class="mt-6 pt-5 border-t border-[color:var(--color-border)] grid grid-cols-2 gap-3">
        <div>
          <p class="font-mono text-xs text-[color:var(--color-fg-dim)]">{isES ? 'Pallets' : 'Pallets'}</p>
          <p class="text-2xl font-semibold text-[color:var(--color-accent)]" id="cotton-pallets">0</p>
        </div>
        <div>
          <p class="font-mono text-xs text-[color:var(--color-fg-dim)]">{isES ? 'Sacos' : 'Sacks'}</p>
          <p class="text-2xl font-semibold text-[color:var(--color-violet)]" id="cotton-sacks">0</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  type Det = { id: string; cls: 'pallet' | 'sack'; conf: number; x: number; y: number; w: number; h: number; start: number; end: number };

  const detections: Det[] = [
    { id: 'P-1042', cls: 'pallet', conf: 0.94, x: 105, y: 100, w: 210, h: 240, start: 0.5, end: 12 },
    { id: 'P-1043', cls: 'pallet', conf: 0.91, x: 335, y: 85, w: 180, h: 250, start: 2.0, end: 12 },
    { id: 'P-1044', cls: 'pallet', conf: 0.88, x: 540, y: 110, w: 190, h: 230, start: 3.5, end: 12 },
    { id: 'S-2201', cls: 'sack', conf: 0.92, x: 140, y: 140, w: 60, h: 50, start: 1.0, end: 12 },
    { id: 'S-2202', cls: 'sack', conf: 0.89, x: 215, y: 170, w: 55, h: 45, start: 1.5, end: 12 },
    { id: 'S-2203', cls: 'sack', conf: 0.95, x: 365, y: 130, w: 60, h: 50, start: 2.3, end: 12 },
    { id: 'S-2204', cls: 'sack', conf: 0.86, x: 440, y: 165, w: 55, h: 45, start: 2.8, end: 12 },
    { id: 'S-2205', cls: 'sack', conf: 0.93, x: 560, y: 150, w: 60, h: 50, start: 3.7, end: 12 },
    { id: 'S-2206', cls: 'sack', conf: 0.90, x: 640, y: 175, w: 55, h: 45, start: 4.2, end: 12 },
    { id: 'S-2207', cls: 'sack', conf: 0.87, x: 165, y: 220, w: 55, h: 45, start: 5.5, end: 12 },
    { id: 'S-2208', cls: 'sack', conf: 0.91, x: 380, y: 230, w: 60, h: 50, start: 6.0, end: 12 },
    { id: 'S-2209', cls: 'sack', conf: 0.94, x: 590, y: 240, w: 55, h: 45, start: 6.8, end: 12 },
  ];

  const boxesEl = document.getElementById('cotton-boxes');
  const listEl = document.getElementById('cotton-detections');
  const timeEl = document.getElementById('cotton-time');
  const fpsEl = document.getElementById('cotton-fps');
  const palletEl = document.getElementById('cotton-pallets');
  const sackEl = document.getElementById('cotton-sacks');

  let t = 0;
  let last = performance.now();

  function loop(now: number) {
    const dt = (now - last) / 1000;
    last = now;
    t = (t + dt) % 13;

    if (timeEl) timeEl.textContent = `t=${t.toFixed(1)}s`;
    if (fpsEl) fpsEl.textContent = `FPS: ${(27 + Math.sin(t * 1.7) * 2).toFixed(1)}`;

    const active = detections.filter((d) => t >= d.start && t <= d.end);
    let pallets = 0, sacks = 0;

    if (boxesEl) {
      boxesEl.innerHTML = active.map((d) => {
        const color = d.cls === 'pallet' ? '#34d399' : '#a78bfa';
        const fade = Math.min(1, (t - d.start) * 3);
        if (d.cls === 'pallet') pallets++; else sacks++;
        return `
          <g opacity="${fade}">
            <rect x="${d.x}" y="${d.y}" width="${d.w}" height="${d.h}" fill="none" stroke="${color}" stroke-width="2"/>
            <rect x="${d.x}" y="${d.y - 20}" width="${d.id.length * 7 + 60}" height="18" fill="${color}"/>
            <text x="${d.x + 5}" y="${d.y - 6}" font-family="monospace" font-size="11" fill="#0a0e14" font-weight="600">
              ${d.id} ${(d.conf * 100).toFixed(0)}%
            </text>
          </g>
        `;
      }).join('');
    }

    if (palletEl) palletEl.textContent = String(pallets);
    if (sackEl) sackEl.textContent = String(sacks);

    if (listEl) {
      listEl.innerHTML = active.slice().reverse().map((d) => {
        const color = d.cls === 'pallet' ? 'var(--color-accent)' : 'var(--color-violet)';
        return `
          <div class="flex items-center justify-between gap-3 p-2.5 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
            <div class="flex items-center gap-2.5 min-w-0">
              <span class="inline-block w-1.5 h-1.5 rounded-full" style="background:${color}"></span>
              <span class="font-mono text-xs">${d.id}</span>
              <span class="text-xs text-[color:var(--color-fg-dim)] uppercase">${d.cls}</span>
            </div>
            <span class="font-mono text-xs text-[color:var(--color-fg-muted)]">${(d.conf * 100).toFixed(0)}%</span>
          </div>
        `;
      }).join('');
    }

    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
</script>
