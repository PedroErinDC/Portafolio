---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const groups = [
  {
    titleKey: 'skills.ai' as const,
    items: ['YOLO 11/26', 'PyTorch', 'TensorRT', 'CUDA', 'Faster-Whisper', 'BGE-M3', 'CVAT', 'Jetson Nano', 'NVIDIA Omniverse'],
  },
  {
    titleKey: 'skills.frameworks' as const,
    items: ['React 19', 'Next.js', 'Astro', 'Spring Boot 3', 'FastAPI', 'Node.js', 'tRPC', 'Drizzle ORM'],
  },
  {
    titleKey: 'skills.langs' as const,
    items: ['Python', 'JavaScript', 'TypeScript', 'Java', 'C#', 'Kotlin'],
  },
  {
    titleKey: 'skills.infra' as const,
    items: ['Docker', 'Redis', 'Milvus', 'PostgreSQL', 'MySQL', 'n8n', 'FFmpeg'],
  },
  {
    titleKey: 'skills.tools' as const,
    items: ['Claude Sonnet/Opus', 'Claude Code', 'Codex', 'Qwen2.5', 'Google Stitch', 'HuggingFace'],
  },
];
---

<section id="skills" class="section">
  <div class="container-page">
    <p class="section-kicker">{t('skills.kicker')}</p>
    <h2 class="section-title">{t('skills.title')}</h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mt-10">
      {groups.map((g) => (
        <div class="card p-5">
          <h3 class="text-sm font-mono text-[color:var(--color-accent)] mb-3">
            {t(g.titleKey)}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {g.items.map((it) => (
              <span class="badge">{it}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
