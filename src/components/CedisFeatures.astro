---
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isES = lang === 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const cams = [
  { id: '01', label: isES ? 'Andén Norte' : 'North Dock' },
  { id: '02', label: isES ? 'Recepción' : 'Receiving' },
  { id: '03', label: isES ? 'Andén Sur' : 'South Dock' },
  { id: '04', label: isES ? 'Almacén' : 'Warehouse' },
];

const hourly = [4, 7, 9, 12, 8, 11, 14, 13, 16, 18, 15, 10];
const peak = Math.max(...hourly);
const totalToday = hourly.reduce((a, b) => a + b, 0);

const reportLabel  = isES ? 'Pallets por hora · hoy'    : 'Pallets per hour · today';
const reportPeak   = isES ? 'pico'                       : 'peak';
const reportTotal  = isES ? 'pallets hoy'               : 'pallets today';
const reportAvg    = isES ? 'prom. confianza'           : 'avg confidence';

// Precompute 3 different pseudo-QR patterns (25x25 cells). Different `seedOffset`
// per scenario so each looks unique.
function buildQr(seedOffset: number): { x: number; y: number }[] {
  const cells: { x: number; y: number }[] = [];
  for (let y = 0; y < 25; y++) {
    for (let x = 0; x < 25; x++) {
      const isFinder =
        (x < 7 && y < 7) ||
        (x > 17 && y < 7) ||
        (x < 7 && y > 17);
      let on = false;
      if (isFinder) {
        const fx = x < 7 ? x : (x > 17 ? x - 18 : 0);
        const fy = y < 7 ? y : (y > 17 ? y - 18 : 0);
        const inOuter = fx === 0 || fx === 6 || fy === 0 || fy === 6;
        const inInner = fx >= 2 && fx <= 4 && fy >= 2 && fy <= 4;
        on = inOuter || inInner;
      } else {
        const seed = (((x + seedOffset) * 73856093) ^ ((y + seedOffset * 3) * 19349663)) >>> 0;
        on = (seed % 7) < 3;
      }
      if (on) cells.push({ x, y });
    }
  }
  return cells;
}

const qrPatterns = [buildQr(0), buildQr(11), buildQr(23)];

// 3 scenarios that cycle. Each carries metadata + total sack count.
const qrScenarios = [
  { folio: 'P-1042', sacks: 5, cam: '01', ts: '2026-01-23 13:42' },
  { folio: 'P-1043', sacks: 7, cam: '02', ts: '2026-01-23 14:18' },
  { folio: 'P-1044', sacks: 3, cam: '04', ts: '2026-01-23 14:51' },
];
---

<section class="space-y-6">

  <!-- Objective + my role -->
  <div class="grid md:grid-cols-2 gap-4">
    <div class="card p-5">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-2">// {isES ? 'objetivo' : 'objective'}</p>
      <h3 class="text-base font-semibold mb-2">{isES ? 'Automatizar el conteo de pallets y sacos en CEDIS' : 'Automate pallet & sack counting in distribution centers'}</h3>
      <p class="text-sm text-[color:var(--color-fg-muted)] leading-relaxed">
        {isES
          ? 'Reemplazar la supervisión manual del andén de descarga con visión computacional en vivo. Reduce errores de conteo, acelera la facturación y deja trazabilidad por pallet sin operadores extra.'
          : 'Replace manual loading-dock supervision with live computer vision. Reduces counting errors, speeds up invoicing, and adds per-pallet traceability without extra staff.'}
      </p>
    </div>

    <div class="card p-5">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-2">// {isES ? 'mi aportación principal' : 'my main contribution'}</p>
      <h3 class="text-base font-semibold mb-2">{isES ? 'Entrenamiento del modelo con ROI + segmentación' : 'Model training with ROI + segmentation'}</h3>
      <p class="text-sm text-[color:var(--color-fg-muted)] leading-relaxed">
        {isES
          ? 'Etiquetado del dataset propio en CVAT, entrenamiento de YOLO con segmentación instance-level y regiones de interés (ROI) por andén, y exportación del modelo a TensorRT FP16 para correr en Jetson Nano.'
          : 'Labeling of the in-house dataset in CVAT, training of YOLO with instance segmentation and per-dock regions of interest (ROI), and export to TensorRT FP16 for Jetson Nano edge inference.'}
      </p>
    </div>
  </div>

  <header class="flex items-baseline justify-between flex-wrap gap-2 pt-2">
    <h2 class="text-2xl font-semibold">{isES ? 'Aportaciones al sistema' : 'My contributions to the system'}</h2>
    <p class="font-mono text-xs text-[color:var(--color-fg-dim)]">{isES ? '// lo que construí' : '// what I built'}</p>
  </header>

  <div class="grid lg:grid-cols-3 gap-4 lg:gap-5">

    <!-- DASHBOARD 4-CAM (spans 2 cols on desktop) -->
    <div class="card p-5 lg:col-span-2 overflow-hidden relative">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-1">// dashboard</p>
          <h3 class="text-lg font-semibold">{isES ? 'Dashboard de 4 cámaras simultáneas' : '4-camera live dashboard'}</h3>
          <p class="text-sm text-[color:var(--color-fg-muted)] mt-1">
            {isES
              ? 'Visualización en cuadrícula con streaming HLS de baja latencia, indicadores de salud por cámara y switching entre vistas individuales.'
              : 'Grid view with low-latency HLS streaming, per-camera health indicators and switch to single-view.'}
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 mt-4">
        {cams.map((c, i) => (
          <div class="feat-cam relative aspect-video rounded-md overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-bg)]" style={`--di: ${i}`}>
            <video
              src={`${base}/demos/cams/cam-0${i + 1}.mp4`}
              poster={`${base}/demos/cams/cam-0${i + 1}.jpg`}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label={`Vista CAM-${c.id}`}
              class="absolute inset-0 w-full h-full object-cover"
            ></video>
            <span class="feat-cam__noise"></span>
            <span class="feat-cam__vignette"></span>
            <svg viewBox="0 0 100 56" preserveAspectRatio="none" class="absolute inset-0 w-full h-full z-10">
              <path d="M 4 4 L 12 4 M 4 4 L 4 12" stroke="#34d399" stroke-width="0.8" fill="none"/>
              <path d="M 96 4 L 88 4 M 96 4 L 96 12" stroke="#34d399" stroke-width="0.8" fill="none"/>
              <path d="M 4 52 L 12 52 M 4 52 L 4 44" stroke="#34d399" stroke-width="0.8" fill="none"/>
              <path d="M 96 52 L 88 52 M 96 52 L 96 44" stroke="#34d399" stroke-width="0.8" fill="none"/>
            </svg>
            <div class="absolute top-1.5 left-2 flex items-center gap-1.5 z-20 px-1.5 py-0.5 rounded bg-[color:var(--color-bg)]/60 backdrop-blur-sm">
              <span class="inline-block w-1 h-1 rounded-full bg-[color:var(--color-accent)] feat-cam__live"></span>
              <span class="font-mono text-[9px] text-[color:var(--color-accent)]">CAM-{c.id}</span>
            </div>
            <div class="absolute bottom-1.5 left-2 z-20 px-1.5 py-0.5 rounded bg-[color:var(--color-bg)]/60 backdrop-blur-sm">
              <p class="font-mono text-[9px] text-[color:var(--color-fg-muted)]">{c.label}</p>
            </div>
            <div class="absolute top-1.5 right-2 z-20 px-1.5 py-0.5 rounded bg-[color:var(--color-bg)]/60 backdrop-blur-sm">
              <span class="font-mono text-[8px] text-[color:var(--color-accent)]">{(27 + i * 0.4).toFixed(1)} fps</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-4 flex items-center justify-between text-xs font-mono text-[color:var(--color-fg-dim)] flex-wrap gap-2">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
          {isES ? '4/4 streams activos' : '4/4 streams active'}
        </span>
        <span>HLS · 720p · latencia &lt;1.5s</span>
      </div>
    </div>

    <!-- QR CODE GENERATION -->
    <div class="card p-5 flex flex-col relative overflow-hidden" id="feat-qr-card" data-state="idle">
      <div class="flex items-start justify-between gap-3 mb-1">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-1">// qr emission</p>
          <h3 class="text-lg font-semibold">{isES ? 'Generación automática de QR' : 'Automatic QR generation'}</h3>
        </div>
        <span class="font-mono text-[10px] text-[color:var(--color-fg-muted)] shrink-0 mt-1" id="feat-qr-scn-idx">1/3</span>
      </div>
      <p class="text-sm text-[color:var(--color-fg-muted)] mb-4">
        {isES
          ? 'Al completar el conteo de sacos por pallet, el sistema emite un QR con metadata (folio, fecha, conteo, cámara) listo para escanear en almacén.'
          : 'When sack count completes per pallet, the system emits a QR with metadata (folio, date, count, camera) ready to scan at warehouse.'}
      </p>

      <div class="flex-1 flex items-center justify-center my-2 relative" id="feat-qr-arena">
        <div class="feat-qr-stage relative w-32 h-32 md:w-36 md:h-36">
          <!-- 3 QR patterns, only active scenario visible -->
          {qrPatterns.map((cells, i) => (
            <div class={`feat-qr-pattern ${i === 0 ? 'feat-qr-pattern--active' : ''}`} data-pattern={i}>
              <div class="p-3 rounded-lg bg-white shadow-lg shadow-[color:var(--color-accent-glow)] feat-qr-clickable">
                <svg viewBox="0 0 25 25" shape-rendering="crispEdges" class="w-24 h-24 md:w-28 md:h-28">
                  {cells.map((c) => <rect x={c.x} y={c.y} width="1" height="1" fill="#0a0e14"/>)}
                </svg>
              </div>
            </div>
          ))}

          <!-- Click ripple at QR center (appears briefly when virtual cursor clicks) -->
          <div class="feat-qr-ripple" id="feat-qr-ripple" aria-hidden="true"></div>
        </div>

        <!-- Floating info card (slides in after virtual click) -->
        <div class="feat-qr-card-pop" id="feat-qr-card-pop" aria-hidden="true">
          <div class="flex items-center gap-2 mb-2 pb-2 border-b border-[color:var(--color-border)]">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded bg-[color:var(--color-accent)] text-[color:var(--color-bg)]">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)]">{isES ? 'PALLET ESCANEADO' : 'PALLET SCANNED'}</p>
          </div>
          <div class="font-mono text-[11px] space-y-1">
            <div class="flex justify-between gap-3"><span class="text-[color:var(--color-fg-dim)]">folio</span><span class="text-[color:var(--color-fg)]" id="feat-qr-pop-folio">—</span></div>
            <div class="flex justify-between gap-3"><span class="text-[color:var(--color-fg-dim)]">sacos</span><span class="text-[color:var(--color-accent)]" id="feat-qr-pop-sacks">—</span></div>
            <div class="flex justify-between gap-3"><span class="text-[color:var(--color-fg-dim)]">cam</span><span class="text-[color:var(--color-fg)]" id="feat-qr-pop-cam">—</span></div>
            <div class="flex justify-between gap-3"><span class="text-[color:var(--color-fg-dim)]">ts</span><span class="text-[color:var(--color-fg)]" id="feat-qr-pop-ts">—</span></div>
            <div class="flex justify-between gap-3 pt-1 mt-1 border-t border-[color:var(--color-border)]"><span class="text-[color:var(--color-fg-dim)]">turno</span><span class="text-[color:var(--color-fg)]" id="feat-qr-pop-shift">—</span></div>
          </div>
        </div>

        <!-- Virtual cursor (animated demo pointer) -->
        <svg class="feat-qr-cursor" id="feat-qr-cursor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 3 L19 12 L12 13 L9 20 Z" fill="#fff" stroke="#0a0e14" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
      </div>

      <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-fg-dim)] text-center mt-2" id="feat-qr-hint">
        {isES ? '— demostración automática —' : '— automated demo —'}
      </p>
    </div>

    <!-- RTSP MULTI-STREAM HEALTH -->
    <div class="card p-5 flex flex-col">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-1">// rtsp ingest</p>
      <h3 class="text-lg font-semibold mb-1">{isES ? 'Ingesta RTSP multi-cámara' : 'Multi-camera RTSP ingest'}</h3>
      <p class="text-sm text-[color:var(--color-fg-muted)] mb-4">
        {isES
          ? 'ffmpeg captura simultánea de 4 streams RTSP, conversión a HLS y healthcheck por cámara con auto-reconexión ante stream caído.'
          : 'ffmpeg simultaneous capture of 4 RTSP streams, conversion to HLS and per-camera healthcheck with auto-reconnect on stream loss.'}
      </p>

      <div class="space-y-2 mt-auto" id="feat-rtsp-list">
        {cams.map((c, i) => {
          const ms = [12, 18, 0, 22][i];
          return (
            <div class="feat-rtsp-row flex items-center gap-3 font-mono text-xs" data-idx={i} data-state="idle">
              <span class="text-[color:var(--color-fg-muted)] w-14 shrink-0">CAM-{c.id}</span>

              <span class="feat-rtsp-state shrink-0 inline-flex items-center justify-center w-5 h-5">
                <!-- spinner -->
                <svg class="feat-rtsp-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <circle cx="12" cy="12" r="9" stroke-dasharray="40 60" />
                </svg>
                <!-- check -->
                <svg class="feat-rtsp-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <!-- cross -->
                <svg class="feat-rtsp-cross" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
                <!-- idle dot -->
                <span class="feat-rtsp-idle"></span>
              </span>

              <div class="flex-1 h-1 rounded-full bg-[color:var(--color-border)] overflow-hidden relative">
                <span class="absolute inset-y-0 left-0 feat-rtsp-bar" data-ms={ms}></span>
              </div>

              <span class="feat-rtsp-value w-20 text-right shrink-0">—</span>
            </div>
          );
        })}
      </div>

      <div class="mt-4 pt-3 border-t border-[color:var(--color-border)] flex items-center justify-between text-xs font-mono">
        <span class="text-[color:var(--color-fg-dim)]">{isES ? 'estado red' : 'network'}</span>
        <span id="feat-rtsp-status" class="inline-flex items-center gap-1.5 text-[color:var(--color-accent)]">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
          —
        </span>
      </div>
    </div>

    <!-- REPORTS -->
    <div class="card p-5 lg:col-span-2 flex flex-col relative">
      <div class="flex items-start justify-between gap-3 mb-1">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-accent)] mb-1">// analytics</p>
          <h3 class="text-lg font-semibold">{isES ? 'Reportes y métricas operativas' : 'Operational reports & metrics'}</h3>
        </div>
        <span class="font-mono text-[10px] text-[color:var(--color-accent)] inline-flex items-center gap-1.5 shrink-0 mt-1">
          <span class="inline-block w-1 h-1 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
          LIVE
        </span>
      </div>
      <p class="text-sm text-[color:var(--color-fg-muted)] mb-4">
        {isES
          ? 'Exportación CSV / PDF de conteos diarios, picos por turno y promedio de confianza por cámara.'
          : 'CSV / PDF export of daily counts, shift peaks and avg confidence per camera.'}
      </p>

      <div class="feat-dash" id="feat-dash">

        <!-- PANEL 0: hourly bar chart -->
        <div class="feat-dash__panel" data-panel="0">
          <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)] mb-2">{reportLabel}</p>
          <svg viewBox="0 0 240 80" class="w-full h-20" id="feat-bars-svg">
            {hourly.map((v, i) => {
              const h = (v / peak) * 70;
              const x = i * 20 + 2;
              const y = 78 - h;
              const isPeak = v === peak;
              const isLive = i === hourly.length - 1;
              return (
                <g>
                  <rect x={x} y={y} width="14" height={h} rx="2"
                        fill={isPeak ? '#34d399' : 'rgba(52, 211, 153, 0.35)'}
                        class={`feat-bar ${isLive ? 'feat-bar--live' : ''}`}
                        style={`--di: ${i}`}
                        data-base={v}
                        data-idx={i}/>
                </g>
              );
            })}
            <line x1="0" y1="78" x2="240" y2="78" stroke="#1f2733" stroke-width="1"/>
          </svg>

          <div class="grid grid-cols-3 gap-2 mt-4 pt-3 border-t border-[color:var(--color-border)]">
            <div>
              <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase">{reportTotal}</p>
              <p class="text-lg font-semibold text-[color:var(--color-accent)] feat-stat" id="feat-stat-total" data-target={totalToday}>0</p>
            </div>
            <div>
              <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase">{reportPeak}</p>
              <p class="text-lg font-semibold feat-stat" id="feat-stat-peak" data-target={peak}><span class="feat-stat__val">0</span><span class="text-xs text-[color:var(--color-fg-dim)]"> /h</span></p>
            </div>
            <div>
              <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase">{reportAvg}</p>
              <p class="text-lg font-semibold feat-stat" id="feat-stat-conf" data-target="92"><span class="feat-stat__val">0</span><span class="text-xs text-[color:var(--color-fg-dim)]">%</span></p>
            </div>
          </div>
        </div>

        <!-- PANEL 1: donut / radial -->
        <div class="feat-dash__panel" data-panel="1">
          <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)] mb-2">{isES ? 'Cumplimiento de turno · hoy' : 'Shift target · today'}</p>

          <div class="flex items-center gap-5">
            <div class="relative shrink-0 w-28 h-28 md:w-32 md:h-32">
              <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
                <circle cx="50" cy="50" r="42" fill="none" stroke="var(--color-border)" stroke-width="9"/>
                <circle cx="50" cy="50" r="42" fill="none" stroke="#34d399" stroke-width="9"
                        stroke-linecap="round" stroke-dasharray="264"
                        stroke-dashoffset="264" id="feat-donut-arc"/>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <p class="text-2xl md:text-3xl font-semibold text-[color:var(--color-accent)] leading-none" id="feat-donut-pct">0%</p>
                <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase mt-1">{isES ? 'meta 160' : 'goal 160'}</p>
              </div>
            </div>

            <div class="flex-1 space-y-2 text-xs font-mono">
              <div class="flex items-center justify-between">
                <span class="text-[color:var(--color-fg-dim)]">{isES ? 'turno actual' : 'shift'}</span>
                <span class="text-[color:var(--color-fg)]">vespertino</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[color:var(--color-fg-dim)]">{isES ? 'pallets' : 'pallets'}</span>
                <span class="text-[color:var(--color-accent)]"><span id="feat-donut-count">0</span> / 160</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[color:var(--color-fg-dim)]">{isES ? 'operadores' : 'operators'}</span>
                <span class="text-[color:var(--color-fg)]">4 activos</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[color:var(--color-fg-dim)]">{isES ? 'eta cierre' : 'eta close'}</span>
                <span class="text-[color:var(--color-fg)]">~ 18:42</span>
              </div>
            </div>
          </div>
        </div>

        <!-- PANEL 2: KPI grid with sparklines -->
        <div class="feat-dash__panel" data-panel="2">
          <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)] mb-2">{isES ? 'Tendencia · últimos 7 días' : 'Trend · last 7 days'}</p>

          <div class="grid grid-cols-2 gap-3">
            <div class="p-3 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
              <div class="flex items-center justify-between mb-1">
                <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase">{isES ? 'Pallets/día' : 'Pallets/day'}</p>
                <span class="font-mono text-[9px] text-[color:var(--color-accent)] inline-flex items-center gap-0.5">↗ +8.4%</span>
              </div>
              <p class="text-xl font-semibold text-[color:var(--color-accent)]">142</p>
              <svg viewBox="0 0 100 22" class="w-full h-5 mt-1">
                <polyline points="0,16 16,14 32,10 48,12 64,8 80,6 100,4"
                          fill="none" stroke="#34d399" stroke-width="1.5" stroke-linecap="round" class="feat-spark"/>
                <circle cx="100" cy="4" r="1.8" fill="#34d399"/>
              </svg>
            </div>
            <div class="p-3 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
              <div class="flex items-center justify-between mb-1">
                <p class="font-mono text-[9px] text-[color:var(--color-fg-dim)] uppercase">{isES ? 'Tiempo prom.' : 'Avg time'}</p>
                <span class="font-mono text-[9px] text-[#fb7185] inline-flex items-center gap-0.5">↘ -12s</span>
              </div>
              <p class="text-xl font-semibold">3:42<span class="text-xs text-[color:var(--color-fg-dim)]"> min</span></p>
              <svg viewBox="0 0 100 22" class="w-full h-5 mt-1">
                <polyline points="0,4 16,6 32,8 48,7 64,10 80,12 100,16"
                          fill="none" stroke="#fb7185" stroke-width="1.5" stroke-linecap="round" class="feat-spark"/>
                <circle cx="100" cy="16" r="1.8" fill="#fb7185"/>
              </svg>
            </div>
            <div class="p-3 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
