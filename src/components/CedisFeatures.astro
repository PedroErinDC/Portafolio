<script>
  type RtspState = 'idle' | 'connecting' | 'valid' | 'invalid';
  type RtspCfg = { final: RtspState; ms: number; value: string };

  // CAM-03 ends as INVALID (auto-reconnect scenario). Others validate fine.
  const RTSP_CFG: RtspCfg[] = [
    { final: 'valid',   ms: 12, value: '12 ms'   },
    { final: 'valid',   ms: 18, value: '18 ms'   },
    { final: 'invalid', ms: 0,  value: 'timeout' },
    { final: 'valid',   ms: 22, value: '22 ms'   },
  ];

  // Timeline (seconds) per row: connecting start, final settle.
  // Each row staggers ~1.2s so the visitor can follow the flow.
  const RTSP_TIMELINE = [
    { connect: 0.8, settle: 2.2 },
    { connect: 2.0, settle: 3.4 },
    { connect: 3.4, settle: 5.0 },
    { connect: 4.6, settle: 6.0 },
  ];
  const CYCLE = 10; // seconds per loop, including idle tail

  const rows = Array.from(document.querySelectorAll<HTMLElement>('#feat-rtsp-list .feat-rtsp-row'));
  const statusEl = document.getElementById('feat-rtsp-status');

  function setRow(row: HTMLElement, state: RtspState, label: string) {
    if (row.dataset.state !== state) row.dataset.state = state;
    const valEl = row.querySelector<HTMLElement>('.feat-rtsp-value');
    if (valEl && valEl.textContent !== label) valEl.textContent = label;
  }

  const start = performance.now();
  function tick() {
    const t = ((performance.now() - start) / 1000) % CYCLE;

    let validCount = 0;
    let invalidCount = 0;
    rows.forEach((row, i) => {
      const cfg = RTSP_CFG[i];
      const timing = RTSP_TIMELINE[i];
      let state: RtspState;
      let label: string;

      if (t < timing.connect) {
        state = 'idle';
        label = '—';
      } else if (t < timing.settle) {
        state = 'connecting';
        label = 'conectando…';
      } else {
        state = cfg.final;
        label = cfg.value;
      }

      setRow(row, state, label);
      if (state === 'valid')   validCount++;
      if (state === 'invalid') invalidCount++;
    });

    if (statusEl) {
      const total = rows.length;
      if (invalidCount > 0) {
        statusEl.innerHTML = `<span class="inline-block w-1.5 h-1.5 rounded-full bg-[#fb7185] animate-pulse"></span> ${validCount}/${total} · 1 reconectando`;
        statusEl.style.color = '#fb7185';
      } else if (validCount === total) {
        statusEl.innerHTML = `<span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span> OK · ${total}/${total}`;
        statusEl.style.color = 'var(--color-accent)';
      } else {
        statusEl.innerHTML = `<span class="inline-block w-1.5 h-1.5 rounded-full bg-[#fbbf24] animate-pulse"></span> handshake · ${validCount}/${total}`;
        statusEl.style.color = '#fbbf24';
      }
    }

    requestAnimationFrame(tick);
  }

  if (rows.length) requestAnimationFrame(tick);

  // ===== Reports & metrics live animation =====
  const statTotal = document.getElementById('feat-stat-total');
  const statPeak  = document.getElementById('feat-stat-peak');
  const statConf  = document.getElementById('feat-stat-conf');
  const toastEl   = document.getElementById('feat-toast');
  const liveBar   = document.querySelector<SVGRectElement>('.feat-bar--live');

  function setStatNumber(el: HTMLElement | null, value: number) {
    if (!el) return;
    const valEl = el.querySelector<HTMLElement>('.feat-stat__val');
    if (valEl) valEl.textContent = String(value);
    else el.textContent = String(value);
  }

  function animateCountUp(el: HTMLElement | null, target: number, duration = 1100) {
    if (!el) return;
    const start = performance.now();
    function step(now: number) {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      const v = Math.round(eased * target);
      setStatNumber(el, v);
      if (t < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  if (statTotal) animateCountUp(statTotal, Number(statTotal.dataset.target ?? 0));
  if (statPeak)  animateCountUp(statPeak,  Number(statPeak.dataset.target  ?? 0), 1300);
  if (statConf)  animateCountUp(statConf,  Number(statConf.dataset.target  ?? 0), 1500);

  // Simulate a new pallet being logged every few seconds.
  let totalNow = Number(statTotal?.dataset.target ?? 137);
  let liveBase = liveBar ? Number(liveBar.dataset.base ?? 10) : 10;

  function bumpPallet() {
    totalNow += 1;
    liveBase += 1;
    if (statTotal) {
      setStatNumber(statTotal, totalNow);
      statTotal.classList.remove('feat-stat--flash');
      void statTotal.offsetWidth;
      statTotal.classList.add('feat-stat--flash');
    }
    if (liveBar) {
      const peakAttr = 18; // visual reference peak
      const newPct = Math.min(1.05, liveBase / peakAttr);
      const newH = newPct * 70;
      const newY = 78 - newH;
      liveBar.setAttribute('height', String(newH));
      liveBar.setAttribute('y', String(newY));
    }
    if (toastEl) {
      toastEl.classList.remove('feat-toast--show');
      void toastEl.offsetWidth;
      toastEl.classList.add('feat-toast--show');
    }
  }

  setInterval(bumpPallet, 5500);

  // Subtle confidence jitter ± 1%.
  if (statConf) {
    setInterval(() => {
      const base = Number(statConf.dataset.target ?? 92);
      const jitter = Math.round((Math.random() - 0.5) * 2);
      setStatNumber(statConf, Math.max(0, Math.min(99, base + jitter)));
    }, 1800);
  }

  // ===== Dashboard panel cycling =====
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.feat-dash__panel'));
  const dots   = Array.from(document.querySelectorAll<HTMLButtonElement>('.feat-dot'));
  const PANEL_INTERVAL_MS = 6500;
  let panelIdx = 0;
  let panelTimer: number | null = null;

  const donutArc   = document.getElementById('feat-donut-arc') as SVGCircleElement | null;
  const donutPct   = document.getElementById('feat-donut-pct');
  const donutCount = document.getElementById('feat-donut-count');
  let donutCurrent = 137;
  const DONUT_GOAL = 160;
  const DONUT_CIRC = 264; // 2 * PI * r (r=42)

  function showPanel(idx: number, animateDonut = true) {
    panelIdx = idx;
    panels.forEach((p, i) => p.classList.toggle('feat-dash__panel--active', i === idx));
    dots.forEach((d, i) => d.classList.toggle('feat-dot--active', i === idx));

    if (idx === 1 && donutArc && donutPct && donutCount && animateDonut) {
      // animate donut to current value
      const targetPct = donutCurrent / DONUT_GOAL;
      const start = performance.now();
      const duration = 900;
      function step(now: number) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        const pct = targetPct * eased;
        if (donutArc) donutArc.setAttribute('stroke-dashoffset', String(DONUT_CIRC * (1 - pct)));
        if (donutPct)   donutPct.textContent   = `${Math.round(pct * 100)}%`;
        if (donutCount) donutCount.textContent = String(Math.round(donutCurrent * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
  }

  function nextPanel() {
    showPanel((panelIdx + 1) % panels.length);
  }

  function startCycle() {
    if (panelTimer !== null) return;
    panelTimer = window.setInterval(nextPanel, PANEL_INTERVAL_MS);
  }
  function stopCycle() {
    if (panelTimer !== null) {
      clearInterval(panelTimer);
      panelTimer = null;
    }
  }

  dots.forEach((d) => {
    d.addEventListener('click', () => {
      const idx = Number(d.dataset.go ?? 0);
      stopCycle();
      showPanel(idx);
      // Restart cycle after manual click.
      setTimeout(startCycle, PANEL_INTERVAL_MS);
    });
  });

  // Init: show first panel, start cycling.
  showPanel(0, false);
  startCycle();

  // Keep donut count in sync with pallet bumps.
  const origBumpTotal = totalNow;
  setInterval(() => {
    donutCurrent = Math.min(DONUT_GOAL, donutCurrent + 1);
    if (panelIdx === 1) showPanel(1, false);
  }, 5500);

  // ===== QR scenarios — virtual-click demo =====
  type QrScn = { folio: string; sacks: number; cam: string; ts: string; shift: string };
  const qrScenarios: QrScn[] = [
    { folio: 'P-1042', sacks: 5, cam: '01', ts: '2026-01-23 13:42', shift: 'matutino' },
    { folio: 'P-1043', sacks: 7, cam: '02', ts: '2026-01-23 14:18', shift: 'vespertino' },
    { folio: 'P-1044', sacks: 3, cam: '04', ts: '2026-01-23 14:51', shift: 'vespertino' },
  ];

  const qrCard      = document.getElementById('feat-qr-card');
  const qrIdxEl     = document.getElementById('feat-qr-scn-idx');
  const qrPatterns2 = Array.from(document.querySelectorAll<HTMLElement>('.feat-qr-pattern'));
  const qrCursor    = document.getElementById('feat-qr-cursor');
  const qrRipple    = document.getElementById('feat-qr-ripple');
  const qrPop       = document.getElementById('feat-qr-card-pop');
  const popFolio    = document.getElementById('feat-qr-pop-folio');
  const popSacks    = document.getElementById('feat-qr-pop-sacks');
  const popCam      = document.getElementById('feat-qr-pop-cam');
  const popTs       = document.getElementById('feat-qr-pop-ts');
  const popShift    = document.getElementById('feat-qr-pop-shift');

  let qrScnIdx = 0;
  let qrTimers: number[] = [];

  function clearQrTimers() {
    qrTimers.forEach((t) => clearTimeout(t));
    qrTimers = [];
  }

  function setQrCardState(s: string) {
    if (qrCard) qrCard.dataset.state = s;
  }

  function runQrScenario(idx: number) {
    clearQrTimers();
    const scn = qrScenarios[idx];

    qrPatterns2.forEach((p, i) => p.classList.toggle('feat-qr-pattern--active', i === idx));
    if (qrIdxEl) qrIdxEl.textContent = `${idx + 1}/${qrScenarios.length}`;

    if (popFolio) popFolio.textContent = scn.folio;
    if (popSacks) popSacks.textContent = `${scn.sacks}/${scn.sacks} ✓`;
    if (popCam)   popCam.textContent   = scn.cam;
    if (popTs)    popTs.textContent    = scn.ts;
    if (popShift) popShift.textContent = scn.shift;

    // Reset visuals
    qrCursor?.classList.remove('feat-qr-cursor--visible', 'feat-qr-cursor--at-qr', 'feat-qr-cursor--press', 'feat-qr-cursor--exit');
    qrPop?.classList.remove('feat-qr-card-pop--visible');
    qrRipple?.classList.remove('feat-qr-ripple--burst');
    setQrCardState('idle');

    // Sequence:
    // 0.7s   → cursor appears bottom-right
    // 1.0s   → cursor glides to QR center (animation 1.1s)
    // 2.2s   → cursor presses (scale 0.85)
    // 2.3s   → ripple burst + pop card slides up
    // 2.4s   → cursor releases (scale back)
    // 6.5s   → pop card fades, cursor moves out
    // 7.6s   → next scenario

    qrTimers.push(window.setTimeout(() => {
      qrCursor?.classList.add('feat-qr-cursor--visible');
    }, 700));

    qrTimers.push(window.setTimeout(() => {
      qrCursor?.classList.add('feat-qr-cursor--at-qr');
    }, 1000));

    qrTimers.push(window.setTimeout(() => {
      qrCursor?.classList.add('feat-qr-cursor--press');
      setQrCardState('press');
    }, 2200));

    qrTimers.push(window.setTimeout(() => {
      // Ripple
      qrRipple?.classList.remove('feat-qr-ripple--burst');
      void qrRipple?.offsetWidth;
      qrRipple?.classList.add('feat-qr-ripple--burst');
      // Pop card
      qrPop?.classList.add('feat-qr-card-pop--visible');
      setQrCardState('info');
    }, 2300));

    qrTimers.push(window.setTimeout(() => {
      qrCursor?.classList.remove('feat-qr-cursor--press');
    }, 2450));

    qrTimers.push(window.setTimeout(() => {
      qrPop?.classList.remove('feat-qr-card-pop--visible');
      qrCursor?.classList.remove('feat-qr-cursor--at-qr');
      qrCursor?.classList.add('feat-qr-cursor--exit');
      setQrCardState('done');
    }, 6500));

    qrTimers.push(window.setTimeout(() => {
      qrScnIdx = (qrScnIdx + 1) % qrScenarios.length;
      runQrScenario(qrScnIdx);
    }, 7600));
  }

  if (qrCard) runQrScenario(0);
</script>
