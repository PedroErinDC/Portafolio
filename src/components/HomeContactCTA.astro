---
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isES = lang === 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const contactHref = isES ? '/contacto' : '/en/contact';
---

<section class="container-page py-10 md:py-14">
  <div class="card p-8 md:p-10 text-center">
    <p class="section-kicker mb-3">{isES ? 'Contacto' : 'Contact'}</p>
    <h2 class="text-2xl md:text-3xl font-semibold mb-3 text-balance">
      {isES ? '¿Hablamos de tu proyecto?' : 'Want to talk?'}
    </h2>
    <p class="text-[color:var(--color-fg-muted)] mb-6 max-w-xl mx-auto">
      {isES
        ? 'Disponible para colaboraciones y posiciones full-time. Respuesta en menos de 24 horas.'
        : 'Open to collaborations and full-time positions. Reply within 24 hours.'}
    </p>
    <a href={base + contactHref} class="btn btn-primary">
      {isES ? 'Ir a contacto' : 'Go to contact'}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
    </a>
  </div>
</section>
