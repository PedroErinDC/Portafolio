---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  summary: string;
  tags: string[];
  year: string;
  role: string;
  backHref: string;
  category: 'work' | 'school';
}

const { lang, title, summary, tags, year, role, backHref, category } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="container-page pt-16 pb-10">
  <a href={base + backHref} class="inline-flex items-center gap-2 text-sm text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)] transition-colors mb-8">
    {t('project.back')}
  </a>

  <div class="flex items-center gap-2 mb-5">
    <span class={`inline-block w-2 h-2 rounded-full ${category === 'work' ? 'bg-[color:var(--color-accent)]' : 'bg-[color:var(--color-violet)]'}`}></span>
    <span class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-fg-dim)]">
      {category === 'work' ? (lang === 'es' ? 'Proyecto laboral' : 'Work project') : (lang === 'es' ? 'Proyecto escolar' : 'School project')}
    </span>
  </div>

  <h1 class="text-3xl md:text-5xl font-semibold mb-5 text-balance leading-tight">
    {title}
  </h1>
  <p class="text-base md:text-lg text-[color:var(--color-fg-muted)] max-w-3xl text-balance mb-8 leading-relaxed">
    {summary}
  </p>

  <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-mono text-[color:var(--color-fg-dim)] mb-4">
    <span><span class="text-[color:var(--color-accent)]">{t('project.tags.year')}:</span> {year}</span>
    <span><span class="text-[color:var(--color-accent)]">{t('project.tags.role')}:</span> {role}</span>
  </div>

  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => <span class="badge">{tag}</span>)}
  </div>
</section>

<div class="container-page mb-10">
  <div class="card p-4 border-dashed bg-transparent">
    <p class="text-xs text-[color:var(--color-fg-dim)] font-mono">
      <span class="text-[color:var(--color-amber)]">⚠</span> {t('project.demo.note')}
    </p>
  </div>
</div>

<section class="container-page mb-16">
  <slot name="demo" />
</section>

<section class="container-page mb-16">
  <h2 class="text-2xl font-semibold mb-6">{t('project.highlights')}</h2>
  <slot name="highlights" />
</section>

<section class="container-page mb-16">
  <h2 class="text-2xl font-semibold mb-6">{t('project.architecture')}</h2>
  <slot name="architecture" />
</section>
