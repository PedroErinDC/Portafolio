---
interface Props {
  title: string;
  summary: string;
  href: string;
  tags: string[];
  year?: string;
  role?: string;
  category?: 'work' | 'school';
  ctaLabel: string;
}

const { title, summary, href, tags, year, role, category = 'work', ctaLabel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a href={base + href} class="card p-6 md:p-7 block group hover-glow">
  <div class="flex items-start justify-between gap-4 mb-4">
    <div class="flex items-center gap-2">
      <span class={`inline-block w-2 h-2 rounded-full ${category === 'work' ? 'bg-[color:var(--color-accent)]' : 'bg-[color:var(--color-violet)]'}`}></span>
      <span class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-fg-dim)]">
        {category === 'work' ? '// laboral' : '// escolar'}
      </span>
    </div>
    {year && <span class="font-mono text-xs text-[color:var(--color-fg-dim)]">{year}</span>}
  </div>

  <h3 class="text-xl md:text-2xl font-semibold mb-2 group-hover:text-[color:var(--color-accent)] transition-colors">
    {title}
  </h3>

  <p class="text-sm text-[color:var(--color-fg-muted)] mb-5 leading-relaxed">{summary}</p>

  <div class="flex flex-wrap gap-1.5 mb-5">
    {tags.map((tag) => <span class="badge">{tag}</span>)}
  </div>

  <div class="flex items-center justify-between pt-4 border-t border-[color:var(--color-border)]">
    {role && <span class="font-mono text-xs text-[color:var(--color-fg-dim)]">{role}</span>}
    <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[color:var(--color-accent)] ml-auto">
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>
