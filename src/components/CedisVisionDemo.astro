---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const isES = lang === 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Precomputed pseudo-QR pattern (25x25 cells).
const qrCells: { x: number; y: number }[] = [];
for (let y = 0; y < 25; y++) {
  for (let x = 0; x < 25; x++) {
    const isFinder =
      (x < 7 && y < 7) ||
      (x > 17 && y < 7) ||
      (x < 7 && y > 17);
    let on = false;
    if (isFinder) {
      const fx = x < 7 ? x : (x > 17 ? x - 18 : 0);
      const fy = y < 7 ? y : (y > 17 ? y - 18 : 0);
      const inOuter = fx === 0 || fx === 6 || fy === 0 || fy === 6;
      const inInner = fx >= 2 && fx <= 4 && fy >= 2 && fy <= 4;
      on = inOuter || inInner;
    } else {
      const seed = ((x * 73856093) ^ (y * 19349663)) >>> 0;
      on = (seed % 7) < 3;
    }
    if (on) qrCells.push({ x, y });
  }
}
---

<div class="card overflow-hidden">
  <div class="p-5 md:p-6 border-b border-[color:var(--color-border)]">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <p class="font-mono text-xs text-[color:var(--color-accent)] mb-1">// {t('project.tags.demo')}</p>
        <h3 class="text-lg font-semibold">{t('cotton.demoTitle')}</h3>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge badge-accent">
          <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse"></span>
          {isES ? 'EN VIVO (simulado)' : 'LIVE (simulated)'}
        </span>
      </div>
    </div>
    <p class="text-sm text-[color:var(--color-fg-muted)] mt-2 max-w-2xl">{t('cotton.demoDesc')}</p>
  </div>

  <div class="grid lg:grid-cols-[2fr_1fr] gap-0">
    <div class="relative bg-black aspect-video overflow-hidden border-b lg:border-b-0 lg:border-r border-[color:var(--color-border)]" id="cv-video-wrap">
      <video
        id="cv-video"
        autoplay
        muted
        playsinline
        preload="auto"
        class="absolute inset-0 w-full h-full object-cover"
      >
        <source src={`${base}/demos/cedis-vision.mp4`} type="video/mp4" />
      </video>

      <div class="cv-video-dim absolute inset-0 pointer-events-none" id="cv-video-dim"></div>

      <svg
        viewBox="0 0 1280 720"
        preserveAspectRatio="xMidYMid slice"
        class="absolute inset-0 w-full h-full pointer-events-none"
      >
        <rect x="0" y="0" width="1280" height="62" fill="#0a0e14" fill-opacity="0.55"/>
        <text x="20" y="28" font-family="monospace" font-size="16" fill="#34d399" font-weight="600">CAM-01 · CEDIS</text>
        <text x="20" y="48" font-family="monospace" font-size="12" fill="#97a3b6">YOLO11-seg · RF-DETR · TensorRT FP16 · Jetson Nano</text>
        <text x="1100" y="28" font-family="monospace" font-size="13" fill="#34d399" id="cv-fps">FPS 28.4</text>
        <text x="1100" y="48" font-family="monospace" font-size="12" fill="#97a3b6" id="cv-time">t=0.0s</text>

        <g id="cv-boxes"></g>

        <rect x="0" y="660" width="1280" height="60" fill="#0a0e14" fill-opacity="0.55"/>
        <text x="20" y="700" font-family="monospace" font-size="13" fill="#97a3b6" id="cv-status">STATUS: monitoring…</text>
      </svg>
    </div>

    <div class="p-5 md:p-6 flex flex-col">
      <div class="flex items-baseline justify-between mb-3 gap-2">
        <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-accent)]">// {isES ? 'alertas en tiempo real' : 'real-time alerts'}</p>
        <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)]">WebSockets</p>
      </div>
      <div id="cv-alerts" class="space-y-2 flex-1 max-h-[480px] overflow-y-auto pr-1"></div>
    </div>
  </div>

  <div class="p-5 md:p-6 border-t border-[color:var(--color-border)]">
    <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-accent)] mb-4">// {isES ? 'detecciones' : 'detections'}</p>

    <div class="grid md:grid-cols-[1fr_auto] gap-6 items-center">
      <div class="grid grid-cols-2 gap-4 max-w-sm">
        <div class="p-3 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
          <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)] uppercase tracking-widest">{isES ? 'Pallets' : 'Pallets'}</p>
          <p class="text-3xl font-semibold text-[color:var(--color-violet)] mt-1" id="cv-pallets">0</p>
        </div>
        <div class="p-3 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]">
          <p class="font-mono text-[10px] text-[color:var(--color-fg-dim)] uppercase tracking-widest">{isES ? 'Sacos' : 'Sacks'}</p>
          <p class="text-3xl font-semibold text-[color:var(--color-accent)] mt-1" id="cv-sacks">0</p>
        </div>
      </div>

      <!-- QR / done area -->
      <div class="cv-qr-wrap flex flex-col items-center" id="cv-qr-wrap" data-state="idle">
        <div class="cv-qr-box relative">
          <!-- QR (shown when done) -->
          <div class="cv-qr-code">
            <svg viewBox="0 0 25 25" shape-rendering="crispEdges" class="w-32 h-32 md:w-36 md:h-36">
              {qrCells.map((c) => <rect x={c.x} y={c.y} width="1" height="1" fill="#0a0e14"/>)}
            </svg>
          </div>
          <!-- Spinner (shown when generating, brief) -->
          <div class="cv-qr-spinner" aria-hidden="true">
            <svg viewBox="0 0 50 50" class="w-12 h-12">
              <circle cx="25" cy="25" r="20" fill="none" stroke="rgba(52,211,153,0.18)" stroke-width="4"/>
              <circle cx="25" cy="25" r="20" fill="none" stroke="#34d399" stroke-width="4"
                      stroke-linecap="round" stroke-dasharray="80 200" class="cv-qr-spinner__arc"/>
            </svg>
          </div>
          <!-- Checkmark (brief on transition) -->
          <div class="cv-qr-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="none" stroke="#34d399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
        </div>
        <p class="cv-qr-caption font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-fg-dim)] mt-3" id="cv-qr-caption">
          {isES ? 'esperando…' : 'waiting…'}
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Video dim overlay (during QR generation) */
  .cv-video-dim {
    background: rgba(10, 14, 20, 0.55);
    opacity: 0;
    transition: opacity 400ms ease;
  }

  #cv-video-wrap[data-state="generating"] .cv-video-dim,
  #cv-video-wrap[data-state="done"] .cv-video-dim {
    opacity: 1;
  }

  /* QR / Loading area */
  .cv-qr-wrap {
    min-width: 160px;
  }

  .cv-qr-box {
    width: 9rem;
    height: 9rem;
    border-radius: 12px;
    background: var(--color-bg-elev);
    border: 1px dashed var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: border-color 300ms ease, background 300ms ease, box-shadow 300ms ease;
  }

  .cv-qr-wrap[data-state="done"] .cv-qr-box {
    background: #fff;
    border: 1px solid var(--color-accent);
    border-style: solid;
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--color-accent) 22%, transparent),
      0 12px 24px -10px rgba(0, 0, 0, 0.5);
  }

  .cv-qr-code,
  .cv-qr-spinner,
  .cv-qr-check {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 250ms ease, transform 320ms ease;
  }

  /* idle: nothing visible — gray empty frame */
  .cv-qr-code    { opacity: 0; transform: scale(0.85); pointer-events: none; }
  .cv-qr-spinner { opacity: 0; pointer-events: none; }
  .cv-qr-check   { opacity: 0; transform: scale(0.6); pointer-events: none; }

  /* generating: spinner */
  .cv-qr-wrap[data-state="generating"] .cv-qr-spinner { opacity: 1; }

  /* done: QR visible + brief checkmark animation */
  .cv-qr-wrap[data-state="done"] .cv-qr-code {
    opacity: 1;
    transform: scale(1);
    animation: cv-qr-pop 380ms cubic-bezier(0.3, 1.3, 0.5, 1);
  }
  .cv-qr-wrap[data-state="done"] .cv-qr-check {
    animation: cv-qr-check 1.2s ease-out;
  }

  @keyframes cv-qr-pop {
    0%   { opacity: 0; transform: scale(0.5); }
    100% { opacity: 1; transform: scale(1);   }
  }

  @keyframes cv-qr-check {
    0%   { opacity: 0; transform: scale(0.4); }
    35%  { opacity: 1; transform: scale(1.15); }
    70%  { opacity: 1; transform: scale(1);   }
    100% { opacity: 0; transform: scale(1.4); }
  }

  .cv-qr-spinner__arc {
    transform-origin: 25px 25px;
    animation: cv-spin 1.05s linear infinite;
  }

  @keyframes cv-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cv-qr-spinner__arc { animation: none; }
  }
</style>

<script>
  type Det = {
    id: string;
    cls: 'pallet' | 'sack';
    conf: number;
    x: number;
    y: number;
    w: number;
    h: number;
    start: number;
    end?: number;
  };

  const detections: Det[] = [
    { id: 'P-1042', cls: 'pallet', conf: 0.94, x: 450, y: 240, w: 420, h: 330, start:  0.8, end: 14.30 },
    { id: 'S-2201', cls: 'sack',   conf: 0.92, x: 440, y: 270, w: 230, h: 245, start:  3.0, end: 10.32 },
    { id: 'S-2202', cls: 'sack',   conf: 0.89, x: 650, y: 280, w: 230, h: 250, start:  5.4, end: 10.32 },
    { id: 'S-2203', cls: 'sack',   conf: 0.91, x: 490, y: 180, w: 300, h: 115, start:  7.2, end: 10.32 },
    { id: 'S-2204', cls: 'sack',   conf: 0.87, x: 425, y: 180, w: 250, h: 240, start: 10.60, end: 14.30 },
    { id: 'S-2205', cls: 'sack',   conf: 0.87, x: 650, y: 180, w: 250, h: 240, start: 13.00, end: 14.30 },
  ];

  // A sack starts as "pending" (yellow) and turns "confirmed" (green) after this delay.
  const CONFIRM_DELAY = 0.5;
  // Extra "QR generation" delay after the last sack is confirmed.
  const QR_GEN_DELAY = 0.5;

  const totalSacks = detections.filter((d) => d.cls === 'sack').length;
  const lastSackStart = Math.max(...detections.filter((d) => d.cls === 'sack').map((d) => d.start));
  const QR_READY_AT = lastSackStart + CONFIRM_DELAY + QR_GEN_DELAY;

  const video     = document.getElementById('cv-video') as HTMLVideoElement | null;
  const videoWrap = document.getElementById('cv-video-wrap');
  const boxesEl   = document.getElementById('cv-boxes');
  const timeEl    = document.getElementById('cv-time');
  const fpsEl     = document.getElementById('cv-fps');
  const palletEl  = document.getElementById('cv-pallets');
  const sackEl    = document.getElementById('cv-sacks');
  const statusEl  = document.getElementById('cv-status');
  const alertsEl  = document.getElementById('cv-alerts');
  const qrWrap    = document.getElementById('cv-qr-wrap');
  const qrCaption = document.getElementById('cv-qr-caption');

  type AlertItem = { t: number; tag: 'INFO' | 'WARN'; text: string };
  const alerts: AlertItem[] = [
    { t:  0.9, tag: 'INFO', text: 'Pallet P-1042 detectado · andén 01' },
    { t:  3.6, tag: 'INFO', text: 'Saco S-2201 confirmado' },
    { t:  6.0, tag: 'INFO', text: 'Saco S-2202 confirmado' },
    { t:  7.8, tag: 'INFO', text: 'Saco S-2203 confirmado' },
    { t:  9.4, tag: 'WARN', text: 'Pausa de operador · 4s · CAM-01' },
    { t: 11.2, tag: 'INFO', text: 'Saco S-2204 confirmado' },
    { t: 13.6, tag: 'INFO', text: 'Saco S-2205 confirmado · pallet completo' },
    { t: 14.0, tag: 'INFO', text: 'QR-1042 emitido ✓' },
  ];

  function tsForTime(secs: number): string {
    const m = Math.floor(secs / 60);
    const s = Math.floor(secs % 60);
    return `13:${(40 + m).toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  }

  // Pallet = violet. Sack starts yellow ("pending"), turns green when confirmed.
  function colorOf(d: Det, t: number): string {
    if (d.cls === 'pallet') return '#a78bfa';
    return (t - d.start) >= CONFIRM_DELAY ? '#34d399' : '#fbbf24';
  }

  function isConfirmed(d: Det, t: number): boolean {
    return d.cls === 'pallet' || (t - d.start) >= CONFIRM_DELAY;
  }

  function noise(seed: string, tick: number): number {
    let h = 2166136261;
    const s = seed + ':' + tick;
    for (let i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = (h * 16777619) >>> 0;
    }
    return (h % 1000) / 1000;
  }

  function dynamicConf(d: Det, t: number): number {
    const age = t - d.start;
    if (age < 0) return 0;
    if (age < 0.7) {
      const tick = Math.floor(t * 10);
      const n = noise(d.id, tick);
      const ramp = age / 0.7;
      const lo = 0.55 + ramp * 0.20;
      const hi = Math.min(0.99, d.conf + 0.04);
      return lo + (hi - lo) * n;
    }
    const tick = Math.floor(t * 4);
    const n = noise(d.id, tick);
    const jitter = (n - 0.5) * 0.04;
    return Math.max(0, Math.min(1, d.conf + jitter));
  }

  function render() {
    const t = video && !Number.isNaN(video.currentTime) ? video.currentTime : 0;

    if (timeEl) timeEl.textContent = `t=${t.toFixed(1)}s`;
    if (fpsEl)  fpsEl.textContent  = `FPS ${(27 + Math.sin(t * 1.7) * 2).toFixed(1)}`;

    const activeBoxes = detections.filter((d) => t >= d.start && t <= (d.end ?? Infinity));
    const activeCumulative = detections.filter((d) => t >= d.start);

    // Counters only include confirmed detections.
    let pallets = 0;
    let sacks = 0;
    for (const d of activeCumulative) {
      if (!isConfirmed(d, t)) continue;
      if (d.cls === 'pallet') pallets++; else sacks++;
    }

    if (boxesEl) {
      boxesEl.innerHTML = activeBoxes.map((d) => {
        const color = colorOf(d, t);
        const fade  = Math.min(1, (t - d.start) * 3.5);
        const confNow = dynamicConf(d, t);
        const confStr = (confNow * 100).toFixed(0).padStart(2, ' ');
        const label  = `${d.id}  ${confStr}%`;
        const labelW = label.length * 9 + 18;
        return `
          <g opacity="${fade.toFixed(2)}">
            <rect x="${d.x}" y="${d.y}" width="${d.w}" height="${d.h}"
                  fill="${color}" fill-opacity="0.08"
                  stroke="${color}" stroke-width="3"/>
            <rect x="${d.x - 1}" y="${d.y - 26}" width="${labelW}" height="24"
                  fill="${color}"/>
            <text x="${d.x + 8}" y="${d.y - 9}"
                  font-family="monospace" font-size="14" font-weight="700"
                  fill="#0a0e14">${label}</text>
          </g>
        `;
      }).join('');
    }

    if (palletEl) palletEl.textContent = String(pallets);
    if (sackEl)   sackEl.textContent   = String(sacks);

    // State machine: idle → generating (after last sack) → done (QR + check)
    const allSacksIn = sacks >= totalSacks && pallets >= 1;
    let state: 'idle' | 'generating' | 'done' = 'idle';
    if (allSacksIn) {
      state = t >= QR_READY_AT ? 'done' : 'generating';
    }

    if (qrWrap)    qrWrap.dataset.state = state;
    if (videoWrap) videoWrap.dataset.state = state;

    if (qrCaption) {
      if (state === 'done')              qrCaption.textContent = 'QR-1042 · emitido ✓';
      else if (state === 'generating')   qrCaption.textContent = 'generando QR…';
      else                                qrCaption.textContent = 'esperando…';
    }

    if (statusEl) {
      if (state === 'done') {
        statusEl.textContent = 'STATUS: pallet completo ✓  ·  QR-1042 emitido';
        (statusEl as SVGTextElement).setAttribute('fill', '#34d399');
      } else if (activeCumulative.length > 0) {
        statusEl.textContent = `STATUS: monitoreando · ${pallets} pallet · ${sacks}/${totalSacks} sacos`;
        (statusEl as SVGTextElement).setAttribute('fill', '#97a3b6');
      } else {
        statusEl.textContent = 'STATUS: monitoring…';
        (statusEl as SVGTextElement).setAttribute('fill', '#97a3b6');
      }
    }

    if (alertsEl) {
      const fired = alerts.filter((a) => t >= a.t);
      alertsEl.innerHTML = fired.slice().reverse().map((a, i) => {
        const tagColor = a.tag === 'WARN' ? '#fbbf24' : '#34d399';
        const age = t - a.t;
        const opacity = i === 0 && age < 0.5 ? Math.min(1, age * 2) : 1;
        return `
          <div class="cv-alert flex items-center gap-3 p-2.5 rounded-lg bg-[color:var(--color-bg-elev)] border border-[color:var(--color-border)]" style="opacity:${opacity.toFixed(2)}">
            <span class="font-mono text-[10px] text-[color:var(--color-fg-dim)] w-14 flex-shrink-0">${tsForTime(a.t)}</span>
            <span class="font-mono text-[10px] px-1.5 py-0.5 rounded flex-shrink-0" style="background:${tagColor};color:#0a0e14">${a.tag}</span>
            <span class="text-sm text-[color:var(--color-fg)] flex-1 leading-tight">${a.text}</span>
          </div>
        `;
      }).join('') || `<p class="font-mono text-xs text-[color:var(--color-fg-dim)] italic">— sin alertas todavía —</p>`;
    }

    requestAnimationFrame(render);
  }

  requestAnimationFrame(render);

  // Hold on the final frame so the QR stays visible long enough to read.
  const END_HOLD_MS = 3000;
  let restartTimer: number | null = null;

  video?.addEventListener('ended', () => {
    if (restartTimer !== null) return;
    restartTimer = window.setTimeout(() => {
      if (!video) return;
      video.currentTime = 0;
      video.play().catch(() => {});
      restartTimer = null;
    }, END_HOLD_MS);
  });

  video?.addEventListener('click', () => video.play().catch(() => {}));
</script>
