---
import { useTranslations, altLangPath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const t = useTranslations(lang);
const alt = altLangPath(lang, pathname);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const isES = lang === 'es';
const links = [
  { key: 'nav.work' as const, href: isES ? '/trabajo' : '/en/work' },
  { key: 'nav.school' as const, href: isES ? '/escuela' : '/en/school' },
  { key: 'nav.contact' as const, href: isES ? '/contacto' : '/en/contact' },
];
const homeHref = isES ? '/' : '/en/';
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--color-bg)]/70 border-b border-[color:var(--color-border)]">
  <div class="container-page flex items-center justify-between h-16">
    <a href={base + homeHref} class="flex items-center gap-2 group">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[color:var(--color-accent)] text-[color:var(--color-bg)] font-mono font-bold group-hover:rotate-3 transition-transform">P</span>
      <span class="font-mono text-sm tracking-tight">pedro<span class="text-[color:var(--color-accent)]">.dev</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {links.map((l) => (
        <a
          href={base + l.href}
          class="px-3 py-2 text-sm text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] transition-colors rounded-md"
        >
          {t(l.key)}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={base + alt.href}
        class="badge hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] transition-colors"
        aria-label={`Switch to ${alt.lang.toUpperCase()}`}
      >
        {alt.lang.toUpperCase()}
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden btn p-2"
        aria-label="Menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-[color:var(--color-border)]">
    <div class="container-page py-3 flex flex-col gap-1">
      {links.map((l) => (
        <a
          href={base + l.href}
          class="px-3 py-2 text-sm text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)]"
        >
          {t(l.key)}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
