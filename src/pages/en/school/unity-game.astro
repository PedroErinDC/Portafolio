---
import Layout from '../../../layouts/Layout.astro';
import ProjectShell from '../../../components/ProjectShell.astro';
import TechCard from '../../../components/TechCard.astro';
import UnityMechanicsCarousel from '../../../components/UnityMechanicsCarousel.astro';
import UnityLevelsMap from '../../../components/UnityLevelsMap.astro';

const lang = 'en' as const;
const highlights = [
  '2D platformer game with three progressive levels plus a final level.',
  'Mechanics implemented in C#: movement, jump, collisions, basic enemies and level triggers.',
  'Scene management and persistence between levels (player state, score).',
  'Level design in the Unity editor with tilemaps and 2D physics.',
  'Built as an academic deliverable at UNAM.',
];
---

<Layout title="Unity Game — Pedro Erin Diaz Cumes" lang={lang}>
  <ProjectShell
    lang={lang}
    title="Educational Game — Unity"
    summary="Multi-level platformer videogame developed in Unity and C# as an academic project during the BSc at UNAM."
    tags={['Unity', 'C#', '2D', 'Game Design', 'Physics 2D', 'Tilemap']}
    year="2023"
    role="Developer"
    backHref="/en/projects"
    category="school"
  >
    <div slot="demo" class="card overflow-hidden">
      <div class="relative aspect-video bg-black">
        <iframe
          src="https://www.youtube-nocookie.com/embed/cZYgQvvw53I?rel=0&modestbranding=1"
          title="Educational Unity Game — Gameplay"
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          class="absolute inset-0 w-full h-full border-0"
        ></iframe>
      </div>

      <div class="p-5 md:p-6 border-t border-[color:var(--color-border)]">
        <div class="flex items-center justify-between flex-wrap gap-3">
          <div>
            <p class="font-mono text-xs text-[color:var(--color-violet)] mb-1">// gameplay</p>
            <h3 class="text-lg font-semibold">Level walkthrough</h3>
          </div>
          <span class="badge" style="background:color-mix(in srgb, var(--color-violet) 18%, transparent); color: var(--color-violet); border-color: var(--color-violet);">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>
            YouTube
          </span>
        </div>
        <p class="text-sm text-[color:var(--color-fg-muted)] mt-2 max-w-2xl">Gameplay video recorded from the full project: mechanics, levels and stage design.</p>
      </div>
    </div>

    <div slot="highlights" class="space-y-8">
      <UnityMechanicsCarousel lang={lang} />

      <UnityLevelsMap lang={lang} />

      <div class="card p-5 md:p-6">
        <p class="font-mono text-[10px] uppercase tracking-widest text-[color:var(--color-violet)] mb-3">// project summary</p>
        <ul class="space-y-3">
          {highlights.map((h) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-violet)] flex-shrink-0"></span>
              <span class="text-sm md:text-base text-[color:var(--color-fg-muted)] leading-relaxed">{h}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div slot="architecture" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      <TechCard id="unity" caption="2D engine" />
      <TechCard id="csharp" caption="scripts" />
      <TechCard id="gamedesign" caption="level design" />
      <TechCard id="tilemap" caption="terrain" />
    </div>
  </ProjectShell>
</Layout>
