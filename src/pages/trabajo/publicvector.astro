---
import Layout from '../../layouts/Layout.astro';
import ProjectShell from '../../components/ProjectShell.astro';
import PublicVectorDemo from '../../components/PublicVectorDemo.astro';

const lang = 'es' as const;
const highlights = [
  'Grabación 24/7 de canales IPTV con segmentación automática en bloques de 30 minutos.',
  'Transcripción multilenguaje con Faster-Whisper large-v3, ~28MB por bloque de audio.',
  'Pipeline de búsqueda semántica con embeddings BGE-M3 (1024-dim) sobre Milvus.',
  'Extracción de contexto y análisis de sentimiento con Qwen2.5-14B (28GB VRAM).',
  'Arquitectura de microservicios en Java 17 + Spring Boot 3 y FastAPI, orquestados con Redis Streams.',
  'Frontend Next.js con dashboard de menciones, sentimiento, filtros por canal/fecha y reproducción de audio.',
];
---

<Layout title="PublicVector — Pedro Erin Diaz Cumes" lang={lang}>
  <ProjectShell
    lang={lang}
    title="PublicVector — Monitoreo de Medios"
    summary="Plataforma que monitorea TV y Radio IPTV en tiempo real. Transcribe con Whisper, busca menciones por embeddings semánticos y extrae contexto con LLM. Todo local, sin costo por uso de APIs."
    tags={['Faster-Whisper', 'BGE-M3', 'Milvus', 'Qwen2.5-14B', 'Spring Boot 3', 'FastAPI', 'Redis Streams', 'PostgreSQL', 'Next.js', 'Java 17']}
    year="2025"
    role="Software Engineer · NLP & Backend"
    backHref="/trabajo"
    category="work"
  >
    <PublicVectorDemo slot="demo" lang={lang} />

    <ul slot="highlights" class="space-y-3">
      {highlights.map((h) => (
        <li class="flex items-start gap-3">
          <span class="mt-2 inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] flex-shrink-0"></span>
          <span class="text-sm md:text-base text-[color:var(--color-fg-muted)] leading-relaxed">{h}</span>
        </li>
      ))}
    </ul>

    <div slot="architecture" class="space-y-6">
      <div class="card p-5 md:p-6">
        <pre class="font-mono text-xs md:text-sm leading-relaxed overflow-x-auto text-[color:var(--color-fg-muted)]"><code>{`┌────────────────────────────────────────────────────────────────────┐
│                       SERVIDOR DE INFERENCIA                       │
│                                                                    │
│  IPTV ──▶ ffmpeg 24/7 ──▶ segmentos .mp3 (30 min, ~28 MB)          │
│                                  │                                 │
│                                  ▼                                 │
│  ┌───────────────────────────────────────────────────┐             │
│  │  GPU pool (puerto :9021)                          │             │
│  │  ├─ Whisper large-v3 (6 GB VRAM)                  │             │
│  │  ├─ BGE-M3 embeddings (2 GB VRAM)                 │             │
│  │  └─ Qwen2.5-14B contexto+sentimiento (28 GB VRAM) │             │
│  └───────────────────────────────────────────────────┘             │
│                                  │                                 │
│                                  ▼                                 │
│  PostgreSQL (textos)  │  Milvus (vectores 1024-d)  │  Redis (cola) │
└────────────────────────┬───────────────────────────────────────────┘
                         │
                         ▼
┌────────────────────────────────────────────────────────────────────┐
│             MICROSERVICIOS (Java 17 + Spring Boot 3)               │
│  ingest · transcribe · search · context · sentiment                │
│  orquestados por Redis Streams (async, alto volumen)               │
└────────────────────────┬───────────────────────────────────────────┘
                         │
                         ▼
┌────────────────────────────────────────────────────────────────────┐
│                  FRONTEND (Next.js · :3003)                        │
│  Dashboard de menciones · filtros · audio · sentimiento            │
└────────────────────────────────────────────────────────────────────┘`}</code></pre>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="card p-5">
          <p class="font-mono text-xs text-[color:var(--color-accent)] mb-2">// ingesta</p>
          <p class="text-sm font-medium mb-1">FFmpeg + Whisper</p>
          <p class="text-xs text-[color:var(--color-fg-muted)]">Grabación IPTV, transcripción multilenguaje</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-xs text-[color:var(--color-accent)] mb-2">// búsqueda</p>
          <p class="text-sm font-medium mb-1">BGE-M3 + Milvus</p>
          <p class="text-xs text-[color:var(--color-fg-muted)]">Embeddings 1024-dim, vector DB</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-xs text-[color:var(--color-accent)] mb-2">// análisis</p>
          <p class="text-sm font-medium mb-1">Qwen2.5-14B</p>
          <p class="text-xs text-[color:var(--color-fg-muted)]">Contexto + sentimiento por mención</p>
        </div>
      </div>
    </div>
  </ProjectShell>
</Layout>
