---
import Layout from '../../layouts/Layout.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';

const lang = 'es' as const;
---

<Layout title="Trabajo — Pedro Erin Diaz Cumes" lang={lang}>
  <div class="container-page pt-16 pb-6">
    <p class="section-kicker">Experiencia laboral</p>
    <h1 class="text-3xl md:text-5xl font-semibold mb-4 text-balance">Proyectos profesionales</h1>
    <p class="text-base md:text-lg text-[color:var(--color-fg-muted)] max-w-2xl text-balance">
      Sistemas en producción construidos en Celestial Dynamics y otros equipos. Foco en visión computacional, edge AI y full-stack.
    </p>
  </div>
  <ProjectsSection lang={lang} />
</Layout>
